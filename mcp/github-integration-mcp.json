{
  "name": "GitHub Integration MCP Server",
  "version": "1.1.0",
  "type": "remote_oauth",
  "description": "Model Context Protocol interface for GitHub repositories",
  "tools": [
    {
      "name": "list_repos",
      "description": "List GitHub user repositories",
      "parameters": { "type": "object", "properties": {} }
    },
    {
      "name": "create_pull_request",
      "description": "Create a GitHub pull request",
      "parameters": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "body": { "type": "string" },
          "head": { "type": "string" },
          "base": { "type": "string" }
        },
        "required": ["title", "head", "base"]
      }
    }
  ]
}
